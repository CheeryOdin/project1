--search function
local items = game.Players.LocalPlayer.Items
local function Update()
	if not scrlfr.Visible then return end
	if #scrlfr:GetChildren() > 2 then
		for _, v in scrlfr:GetChildren() do
			if v:IsA("TextButton") then
				v:Destroy()
				task.wait()
			end
		end
	end
	local text = string.lower(textbox.Text)
	if text == "" then return end
	local buttons = 0
	local posY = 0.02
	for i, item in items:GetChildren() do
		if buttons >= 10 then break end
		local name = string.lower(item.Name)
		if string.find(name, text) then
			local button123 = Instance.new("TextButton", scrlfr)
			button123.Position = UDim2.new(0.08, 0, posY + 0.1 * buttons, 0)
			button123.Size = UDim2.new(0.8, 0, 0.08, 0)
			button123.Text = item.Name
			button123.TextScaled = true
			button123.BackgroundTransparency = 0.95
			button123.MouseButton1Click:Connect(function()
				textbox.Text = item.Name
			end)
			buttons += 1
		end
	end
end
textbox.Changed:Connect(Update)
--function
button.MouseButton1Click:Connect(function()
	for i=1,math.clamp(game.Players.LocalPlayer.Items[textbox.Text].Value, 0, 15) do
		Events.Get("Equip"):FireServer(textbox.Text)
		Events.Get("LocalEquip"):Fire(textbox.Text)
		task.wait(0.2)
		Events.Get("Drop"):FireServer(textbox.Text)
		task.wait(0.2)
	end
end)
