--antigrab func
val:IsA("Model")
local function Proc(v)
	if not val.Value then return end
	if v:WaitForChild("Owner").Value == game.Players.LocalPlayer then
		v.Handle:WaitForChild("TouchInterest"):Destroy()
	end
end
local function ProcT(tabl)
	if not val.Value then return end
	for _, v in tabl do
		if v.Owner.Value == game.Players.LocalPlayer then
			v.Handle.TouchInterest:Destroy()
		end
	end
end
workspace.Dropped.ChildAdded:Connect(Proc)
val.Changed:Connect(function()
	ProcT(workspace.Dropped:GetChildren())
end)
