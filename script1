--some core func
local function goto(destination)
	print("goto func")
	if legitmode then
		hum:MoveTo(destination.Position + Vector3.new(0, 4.25, 0))
		task.wait(0.5)
	else
		chr.PrimaryPart.Anchored = false
		task.wait(0.1)
		chr.PrimaryPart.CFrame = destination.CFrame + Vector3.new(0, 4, 0)
		task.wait(0.1)
		chr.PrimaryPart.Anchored = true
		task.wait(0.1)
		if destination == spawn then
			chr.PrimaryPart.Anchored = false
		end
	end
end
local function panic()
	print("panic func")
	inboard.Value = false
	started.Value = false
	task.wait(0.1)
	goto(spawn)
end
local function check()
	print("check func")
	if not inboard.Value then return end
	if started.Value then
		if board.Player2.Value ~= game.Players[plr2] and board.Player1.Value ~= game.Players[plr2] then
			inboard.Value = false
			started.Value = false
			panic()
		end
	else
		if board.Player2.Value == game.Players[plr2] or board.Player1.Value == game.Players[plr2] then
			started.Value = true
		end
	end
end
local function itemsCheck(plr)
	print("itemcheck func")
	for _, v in workspace.Dropped:GetChildren() do
		if v.Owner.Value == plr then
			items += 1
		end
	end
end
local function Drop()
	print("drop func")
	if items < 15 then
		for i=1,math.clamp(game.Players.LocalPlayer.Items[item].Value, 0, 15-items) do
			Events.Get("Equip"):FireServer(item)
			Events.Get("LocalEquip"):Fire(item)
			task.wait(0.2)
			Events.Get("Drop"):FireServer(item)
			task.wait(0.2)
		end
		itemsCheck(game.Players.LocalPlayer)
		if 15-items ~= 0 then
			Drop()
		end
	else
		items = 0
	end
end
--GIVER
--waiting for second player DONE
--starts give an items until it reaches 15, then press green DONE
--if receiver leaves from trade, it will stopped DONE
--if giver haven't these item anymore, he will leave from trade DONE
local function giver()
	print("giver func")
	if not started.Value then
		inboard.Value = true
		goto(controls.Done.Pad)
		task.wait(0.1)
		board.Player1:GetPropertyChangedSignal("Value"):Connect(check)
		board.Player2:GetPropertyChangedSignal("Value"):Connect(check)
		check()
	else
		if not inboard.Value then panic(); return end
		if not game.Players.LocalPlayer.Items:FindFirstChild(item) or game.Players.LocalPlayer.Items[item].Value < 15 then
			inboard.Value = false
			started.Value = false
			panic()
			return 
		end
		Drop()
		task.wait(0.5)
		if not inboard.Value then panic(); return end
		goto(controls.Done.Pad)
		while not board.TradeFinalizing.Value and inboard.Value do
			task.wait(0.5)
			chr.Humanoid.Jump = true
		end
		giver()
	end
end
--RECEIVER
--waiting for second player DONE
--wait until items reaches 15 and press green, then ~0.5 sec later press red КОСТЫЛЬНУЛ
--if giver leaves from trade, it will stopped DONE
local function receiver()
	print("receiver func")
	if not started.Value then
		inboard.Value = true
		goto(controls.Done.Pad)
		task.wait(0.1)
		board.Player2:GetPropertyChangedSignal("Value"):Connect(check)
		check()
	else
		if not inboard.Value then panic(); return end
		while inboard.Value and started.Value do
			if not inboard.Value then panic(); break end
			goto(controls.Done.Pad)
			task.wait(0.5)
			chr.Humanoid.Jump = true
			task.wait(1)
			goto(controls.Close.Pad)
			task.wait(0.5)
			chr.Humanoid.Jump = true
			task.wait(1)
		end
	end
end
